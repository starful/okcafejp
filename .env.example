# OK Series environment variables
# Replace with real values and keep `.env` gitignored.

GEMINI_API_KEY="YOUR_GEMINI_API_KEY"
# Optional (defaults match other OK series paid usage: 2.5-flash, 5 item / 3 guide workers)
# GEMINI_MODEL="gemini-2.5-flash"
# GEMINI_MAX_WORKERS="5"
# GEMINI_GUIDE_MAX_WORKERS="3"
# Vertex Imagen (okramen 과 동일 — fetch_images.py)
# GCP_PROJECT="your-gcp-project-id"
# GCP_LOCATION="us-central1"
# IMAGEN_MODEL="imagen-4.0-fast-generate-001"
# Places API (New): Nearby + Text Search — used by script/fetch_items_from_places.py
GOOGLE_PLACES_API_KEY="YOUR_PLACES_API_KEY"
MAPS_API_KEY="YOUR_MAPS_JS_API_KEY"
SITE_URL="https://okcafejp.net"
# Optional: override GA (default in config.py is G-P2PSDNKE9D)
# GA_ID="G-P2PSDNKE9D"
ASSET_VERSION="2026-04-29"
